# Database URL for Neon Postgres database connection
DATABASE_URL=

# Better Auth Secret and URLs
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cloudinary credentials for image and document hosting
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pusher credentials for real-time features (chat, notification, deal updates)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2

# Razorpay payments config
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
VITE_RAZORPAY_KEY_ID=

# Resend Email credentials
RESEND_API_KEY=
EMAIL_FROM=noreply@fmi.in

# Upstash Redis for rate limiting, cache, or OTP sessions
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic / OpenAI keys for AI matching, scoring, or analysis
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# App URL and Node Environment
NEXT_PUBLIC_APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
NODE_ENV=development
